{
  "realm": "school",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrative access to the School API"
      },
      {
        "name": "teacher",
        "description": "Teaching access to the School API"
      }
    ]
  },
  "clients": [
    {
      "clientId": "school-api",
      "name": "school-api",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:8180/*"
      ],
      "webOrigins": [
        "+"
      ],
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "School",
      "lastName": "Admin",
      "email": "admin@school.local",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "teacher",
      "enabled": true,
      "emailVerified": true,
      "firstName": "School",
      "lastName": "Teacher",
      "email": "teacher@school.local",
      "credentials": [
        {
          "type": "password",
          "value": "teacher123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "teacher"
      ]
    }
  ]
}
